# Copy this file to .env and fill in ONE of the two options below.
# The agent will use whichever credentials it finds.

# ── Option A: Gemini API key (easiest — recommended for new users) ──────────
# Get a free key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_gemini_api_key_here

# ── Option B: Vertex AI service account (for GCP users) ─────────────────────
# Requires a GCP project with Vertex AI API enabled and a service account JSON.
# GOOGLE_APPLICATION_CREDENTIALS=service-account.json
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
